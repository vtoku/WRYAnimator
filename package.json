{
  "name": "wryanimator",
  "private": true,
  "version": "0.31.1",
  "type": "module",
  "description": "WRYAnimator: edit and clean up Warudo motion-capture recordings in your browser, then export FBX, VRMA, or wanim. Runs entirely client-side.",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "smoke": "node --experimental-strip-types scripts/wanimSmoke.ts",
    "fbxcheck": "node scripts/fbxLoadCheck.mjs",
    "faceFbxCheck": "node scripts/faceFbxCheck.mjs",
    "cleanCheck": "node scripts/cleanCheck.mjs",
    "vrmaCheck": "node scripts/vrmaCheck.mjs",
    "rigCheck": "node scripts/rigCheck.mjs",
    "wanimCheck": "node scripts/wanimCheck.mjs",
    "shogunCheck": "node scripts/shogunCheck.mjs",
    "drive": "node scripts/driveApp.mjs",
    "bootcheck": "node scripts/bootCheck.mjs"
  },
  "dependencies": {
    "three": "^0.169.0"
  },
  "devDependencies": {
    "@types/three": "^0.169.0",
    "playwright": "^1.60.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  }
}
